{
  "id": "domain/edu/v1",
  "version": "1.0.0",
  "domain_authority": {
    "name": "Education Domain",
    "description": "Domain-level physics for the education domain pack. Declares actor shapes, domain-wide invariants, and cross-module state governance."
  },
  "meta_authority_id": "root",

  "actor_schemas": {
    "student": {
      "domain_state": [
        "preferences",
        "assigned_modules",
        "assigned_ta_ids",
        "assigned_guardian_ids"
      ],
      "capabilities": [
        "view_my_profile",
        "view_available_modules",
        "request_module_assignment",
        "update_my_preferences"
      ]
    },
    "teacher": {
      "domain_state": [
        "preferences",
        "assigned_students",
        "assigned_rooms",
        "escalation_preferences",
        "active_standing_order_overrides"
      ],
      "capabilities": [
        "view_student_progress",
        "manage_escalations",
        "assign_module",
        "update_user_preferences"
      ]
    },
    "teaching_assistant": {
      "domain_state": [
        "preferences",
        "assigned_students",
        "supervising_teacher_id"
      ],
      "capabilities": [
        "view_student_progress",
        "provide_hints"
      ]
    },
    "parent": {
      "domain_state": [
        "preferences",
        "assigned_children",
        "notification_preferences"
      ],
      "capabilities": [
        "view_child_progress",
        "update_notification_preferences"
      ]
    },
    "domain_authority": {
      "domain_state": [
        "preferences",
        "management_state"
      ],
      "capabilities": [
        "manage_teachers",
        "manage_modules",
        "view_all_progress",
        "modify_standing_orders",
        "trigger_logic_scrape",
        "test_as_role"
      ]
    }
  },

  "user_commands": {
    "student": ["view_my_profile", "view_available_modules", "request_module_assignment"],
    "teacher": ["view_student_progress", "manage_escalations", "assign_module"],
    "teaching_assistant": ["view_student_progress"],
    "parent": ["view_child_progress"],
    "domain_authority": ["manage_teachers", "manage_modules", "view_all_progress", "modify_standing_orders"]
  },

  "domain_invariants": [
    {
      "id": "content_safety",
      "description": "All interactions must remain age-appropriate and educationally relevant.",
      "severity": "critical"
    },
    {
      "id": "role_boundary",
      "description": "Actors may only access data and operations within their declared capabilities.",
      "severity": "critical"
    },
    {
      "id": "no_chat_persistence",
      "description": "Chat transcripts are never stored server-side. Profile is the only persistent actor state.",
      "severity": "critical"
    }
  ],

  "domain_standing_orders": [
    {
      "id": "escalate_on_safety_concern",
      "description": "If any actor signal suggests harm, self-harm, or abuse, escalate immediately to domain authority.",
      "auto_execute": true
    },
    {
      "id": "consent_required",
      "description": "All student-role actors must accept the magic-circle consent boundary before interaction.",
      "auto_execute": true
    }
  ],

  "domain_roles": {
    "schema_version": "1.0",
    "roles": [
      {
        "role_id": "domain_authority",
        "role_name": "Domain Authority",
        "hierarchy_level": 0,
        "description": "Domain-level administrator with full oversight of the education domain. Inherits all teacher capabilities and adds domain-wide management: teacher roster, module assignments, standing-order modifications, and logic-scrape triggers.",
        "maps_to_system_role": "admin",
        "default_access": "rwx",
        "may_assign_domain_roles": true,
        "max_assignable_level": 3,
        "scoped_capabilities": {
          "receive_escalations": true,
          "modify_standing_orders": true,
          "view_all_student_progress": true,
          "trigger_logic_scrape": true,
          "manage_teachers": true,
          "assign_modules": true
        }
      },
      {
        "role_id": "teacher",
        "role_name": "Teacher",
        "hierarchy_level": 1,
        "description": "Certified instructors who deliver lessons, monitor student progress, and receive escalation packets.",
        "maps_to_system_role": "user",
        "default_access": "rwx",
        "may_assign_domain_roles": true,
        "max_assignable_level": 2,
        "scoped_capabilities": {
          "receive_escalations": true,
          "modify_standing_orders": false,
          "view_all_student_progress": true,
          "trigger_logic_scrape": false
        }
      },
      {
        "role_id": "teaching_assistant",
        "role_name": "Teaching Assistant / Paraprofessional",
        "hierarchy_level": 2,
        "description": "Support staff who help students with guided practice. Can view progress and issue hints but cannot modify domain physics or receive escalations.",
        "maps_to_system_role": "user",
        "default_access": "rx",
        "may_assign_domain_roles": false,
        "scoped_capabilities": {
          "receive_escalations": false,
          "view_student_progress": true,
          "issue_hints": true,
          "view_log_records": true,
          "modify_domain_physics": false
        }
      },
      {
        "role_id": "student",
        "role_name": "Student",
        "hierarchy_level": 3,
        "description": "Learners enrolled in the education domain.",
        "maps_to_system_role": "user",
        "default_access": "x",
        "may_assign_domain_roles": false,
        "scoped_capabilities": {
          "view_own_progress": true,
          "view_other_progress": false,
          "query_glossary": true
        }
      },
      {
        "role_id": "parent",
        "role_name": "Parent / Guardian",
        "hierarchy_level": 2,
        "description": "Parents or guardians who can view their assigned child's progress and receive escalation notifications.",
        "maps_to_system_role": "user",
        "default_access": "r",
        "may_assign_domain_roles": false,
        "scoped_capabilities": {
          "view_assigned_child_progress": true,
          "receive_escalation_notifications": true,
          "query_glossary": true,
          "view_other_progress": false,
          "modify_domain_physics": false
        }
      }
    ],
    "role_acl": [
      {
        "domain_role": "teaching_assistant",
        "access": "rx",
        "scope": "session_monitoring"
      },
      {
        "domain_role": "teaching_assistant",
        "access": "r",
        "scope": "log_records_own_students"
      }
    ]
  },

  "groups": {
    "educators": {
      "description": "Teaching staff with group-level permissions on education modules.",
      "members": {
        "domain_roles": ["domain_authority", "teacher", "teaching_assistant"]
      }
    },
    "learners": {
      "description": "Students enrolled in the domain.",
      "members": {
        "domain_roles": ["student"]
      }
    },
    "guardians": {
      "description": "Parents and guardians with view access to their assigned child's progress.",
      "members": {
        "domain_roles": ["parent"]
      }
    }
  }
}
