{
  "id": "domain/asst/calendar/v1",
  "version": "0.1.0",
  "domain_authority": {
    "name": "Assistant Domain Lead",
    "role": "Domain Authority",
    "pseudonymous_id": "da_assistant_001"
  },
  "meta_authority_id": "root",
  "description": "Calendar task module — handles scheduling, events, reminders, and availability queries. Enforces confirmation before writes and date-range bounding. Short multi-turn shape.",
  "department": "Tasks",
  "lumina_core_version": "1.0.0",
  "invariants": [
    {
      "id": "no_unauthorized_modification",
      "description": "Calendar write operations (create, update, delete) must be confirmed by the user before execution. No silent modifications.",
      "severity": "warning",
      "check": "write_confirmed == true",
      "standing_order_on_violation": "confirm_before_write"
    },
    {
      "id": "date_range_bounded",
      "description": "Calendar queries must have a bounded date range. Unbounded queries default to the current week.",
      "severity": "warning",
      "check": "date_range_specified == true",
      "standing_order_on_violation": "request_date_range"
    },
    {
      "id": "content_safety_hard",
      "description": "Hard safety gate — immediate escalation on harmful content.",
      "severity": "critical",
      "check": "content_safety_flags != []",
      "standing_order_on_violation": "safety_intervene"
    }
  ],
  "standing_orders": [
    {
      "id": "confirm_before_write",
      "action": "confirm_before_write",
      "trigger_condition": "no_unauthorized_modification",
      "max_attempts": 2,
      "escalation_on_exhaust": false,
      "description": "Ask the user to confirm before creating, updating, or deleting calendar entries."
    },
    {
      "id": "request_date_range",
      "action": "request_date_range",
      "trigger_condition": "date_range_bounded",
      "max_attempts": 1,
      "escalation_on_exhaust": false,
      "description": "Ask the user to specify a date range, or default to current week."
    },
    {
      "id": "safety_intervene",
      "action": "escalate",
      "target": "domain_authority",
      "sla_minutes": 5,
      "auto_freeze": true,
      "description": "Immediately escalate on safety violation."
    }
  ],
  "escalation_triggers": [
    {
      "id": "critical_safety_event",
      "condition": "A critical invariant fired (content_safety_hard).",
      "target_role": "domain_authority",
      "sla_minutes": 5
    }
  ],
  "artifacts": [],
  "tool_adapters": [
    "adapter/asst/calendar-api/v1"
  ],
  "module_state_schema": {
    "mastery_dimensions": [],
    "tracked_subsystems": [],
    "custom_fields": {
      "turn_count": {"type": "integer", "default": 0},
      "events_created": {"type": "integer", "default": 0},
      "events_modified": {"type": "integer", "default": 0},
      "pending_confirmation": {"type": "boolean", "default": false}
    }
  }
}
