{
  "id": "domain/asst/planning/v1",
  "version": "0.1.0",
  "domain_authority": {
    "name": "Assistant Domain Lead",
    "role": "Domain Authority",
    "pseudonymous_id": "da_assistant_001"
  },
  "meta_authority_id": "root",
  "description": "Planning task module — handles task planning, project management, to-do lists, goal setting, and organizational tasks. Enforces constraint gathering before execution and no-autonomous-execution policy. Extended multi-turn shape.",
  "department": "Tasks",
  "lumina_core_version": "1.0.0",
  "invariants": [
    {
      "id": "no_autonomous_execution",
      "description": "The assistant must not execute plans autonomously. All action items must be presented for user review and explicit approval.",
      "severity": "warning",
      "check": "execution_approved == true",
      "standing_order_on_violation": "request_execution_approval"
    },
    {
      "id": "constraint_grounded",
      "description": "Plans must be grounded in user-provided constraints (deadlines, resources, priorities). Do not assume constraints.",
      "severity": "warning",
      "check": "constraints_gathered == true",
      "standing_order_on_violation": "gather_constraints_first"
    },
    {
      "id": "content_safety_hard",
      "description": "Hard safety gate — immediate escalation on harmful content.",
      "severity": "critical",
      "check": "content_safety_flags != []",
      "standing_order_on_violation": "safety_intervene"
    }
  ],
  "standing_orders": [
    {
      "id": "gather_constraints_first",
      "action": "gather_constraints_first",
      "trigger_condition": "constraint_grounded",
      "max_attempts": 3,
      "escalation_on_exhaust": false,
      "description": "Ask the user about deadlines, resources, priorities, and dependencies before generating a plan."
    },
    {
      "id": "request_execution_approval",
      "action": "request_execution_approval",
      "trigger_condition": "no_autonomous_execution",
      "max_attempts": 2,
      "escalation_on_exhaust": false,
      "description": "Present the plan and ask for explicit approval before any execution step."
    },
    {
      "id": "safety_intervene",
      "action": "escalate",
      "target": "domain_authority",
      "sla_minutes": 5,
      "auto_freeze": true,
      "description": "Immediately escalate on safety violation."
    }
  ],
  "escalation_triggers": [
    {
      "id": "critical_safety_event",
      "condition": "A critical invariant fired (content_safety_hard).",
      "target_role": "domain_authority",
      "sla_minutes": 5
    }
  ],
  "artifacts": [],
  "tool_adapters": [
    "adapter/asst/planning-tools/v1"
  ],
  "module_state_schema": {
    "mastery_dimensions": [],
    "tracked_subsystems": [],
    "custom_fields": {
      "turn_count": {"type": "integer", "default": 0},
      "plans_created": {"type": "integer", "default": 0},
      "active_plan_id": {"type": "string", "default": null},
      "constraints_gathered": {"type": "boolean", "default": false}
    }
  }
}
